# ──────────────────────────────────────────────────────────────────────────────
# ESG CoPilot — Environment Variables
# Copy this file to .env and fill in your secrets.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── HuggingFace ──────────────────────────────────────────────────────────────
# Required for AI-generated narratives. Without it, rule-based fallbacks are used.
HF_API_TOKEN=

# ── AWS S3 (optional — only if using S3 connector) ──────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Google Cloud (optional — only if using BigQuery or GCS connector) ────────
# Path to service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=

# ── Azure Blob Storage (optional — only if using Azure connector) ────────────
AZURE_STORAGE_CONNECTION_STRING=

# ── SQL Database (optional — only if using SQL connector) ────────────────────
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ── Application Ports ────────────────────────────────────────────────────────
STREAMLIT_PORT=8501
GRADIO_PORT=7860
